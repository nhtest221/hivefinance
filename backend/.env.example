APP_NAME=HiveFinance
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=hivefinance
DB_USERNAME=hivefinance_app
DB_PASSWORD=change-me

CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

SESSION_DRIVER=database
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DECAY_MINUTES=15
MFA_CHALLENGE_TTL_MINUTES=5

AUDIT_RETENTION_DAYS=2555
OUTBOX_BATCH_SIZE=100
