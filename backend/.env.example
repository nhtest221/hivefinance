APP_NAME=HiveFinance
APP_ENV=local
APP_KEY=
APPROVAL_PAYLOAD_RETENTION_DAYS=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=hivefinance
DB_USERNAME=hivefinance_app
DB_PASSWORD=change-me

CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

SESSION_DRIVER=database
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DECAY_MINUTES=15
MFA_CHALLENGE_TTL_MINUTES=5

AUDIT_RETENTION_DAYS=2555
OUTBOX_BATCH_SIZE=100

# M1 policy values are intentionally unset until approved entity configuration is supplied.
HIVEFIN_TAX_JURISDICTIONS=
HIVEFIN_TAX_CALCULATION_METHODS=
HIVEFIN_TAX_EXCLUSIVE_METHODS=
HIVEFIN_TAX_INCLUSIVE_METHODS=
HIVEFIN_TAX_RETURN_BOX_KEYS=
HIVEFIN_TAX_PACK_TEMPLATE_KEYS=
HIVEFIN_TAX_PACK_POLICY_KEYS=
HIVEFIN_FX_SOURCES=
HIVEFIN_FX_SOURCE_PRECEDENCE=
HIVEFIN_FX_ROUNDING_MODE=
HIVEFIN_FX_ROUNDING_SCALE=
HIVEFIN_FX_UNREALISED_GAIN_ACCOUNT_ID=
HIVEFIN_FX_UNREALISED_LOSS_ACCOUNT_ID=

# M3 Settlement values are deployment policy and intentionally have no defaults.
SETTLEMENT_RECEIPT_NUMBER_PREFIX=
SETTLEMENT_RECEIPT_NUMBER_FORMAT=
SETTLEMENT_PAYMENT_NUMBER_PREFIX=
SETTLEMENT_PAYMENT_NUMBER_FORMAT=
SETTLEMENT_REFUND_NUMBER_PREFIX=
SETTLEMENT_REFUND_NUMBER_FORMAT=
SETTLEMENT_CUSTOMER_CREDIT_ACCOUNT_ID=
SETTLEMENT_VENDOR_CREDIT_ACCOUNT_ID=
SETTLEMENT_REALISED_FX_GAIN_ACCOUNT_ID=
SETTLEMENT_REALISED_FX_LOSS_ACCOUNT_ID=
SETTLEMENT_WITHHOLDING_CONFIG_JSON={}

# M2 policy values are intentionally unset. Deployments must supply approved values.
DOCUMENT_SUPPORTED_CURRENCIES=
DOCUMENT_PAYMENT_TERMS_JSON={}
INVOICE_NUMBER_PREFIX=
INVOICE_NUMBER_FORMAT=
INVOICE_REVENUE_ACCOUNT_ID=
INVOICE_RECEIVABLE_ACCOUNT_ID=
BILL_NUMBER_PREFIX=
BILL_NUMBER_FORMAT=
BILL_PAYABLE_ACCOUNT_ID=
EXPENSE_PAYABLE_ACCOUNT_ID=
