# LOCAL/UAT ONLY — illustrative values, credentials and policy. Never deploy.
APP_NAME="HiveFinance M2 UAT"
APP_ENV=local
APP_KEY=base64:VhqKAn/cty9HsYLtGuyEpbcNT7MBhjjGkry1xU6ADKM=
APPROVAL_PAYLOAD_RETENTION_DAYS=30
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080
HIVEFIN_UAT_SEED_ALLOWED=true

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=hivefinance_m2_uat
DB_USERNAME=hivefinance_uat_app
DB_PASSWORD=uat-only-change-me

CACHE_STORE=database
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DECAY_MINUTES=15
MFA_CHALLENGE_TTL_MINUTES=5
AUDIT_RETENTION_DAYS=30
OUTBOX_BATCH_SIZE=100

# Illustrative M2 UAT TaxPack — not a legal or production tax policy.
HIVEFIN_TAX_JURISDICTIONS=BD
HIVEFIN_TAX_CALCULATION_METHODS=exclusive
HIVEFIN_TAX_EXCLUSIVE_METHODS=exclusive
HIVEFIN_TAX_INCLUSIVE_METHODS=
HIVEFIN_TAX_RETURN_BOX_KEYS=UAT-OUTPUT,UAT-INPUT
HIVEFIN_TAX_PACK_TEMPLATE_KEYS=template_key
HIVEFIN_TAX_PACK_POLICY_KEYS=uat_only

# Illustrative USD/BDT rate source and rounding — not a production market source.
HIVEFIN_FX_SOURCES=uat_manual
HIVEFIN_FX_SOURCE_PRECEDENCE=uat_manual
HIVEFIN_FX_ROUNDING_MODE=half_up
HIVEFIN_FX_ROUNDING_SCALE=4
HIVEFIN_FX_UNREALISED_GAIN_ACCOUNT_ID=
HIVEFIN_FX_UNREALISED_LOSS_ACCOUNT_ID=

DOCUMENT_SUPPORTED_CURRENCIES=BDT,USD
DOCUMENT_PAYMENT_TERMS_JSON='{"NET15":15,"NET30":30}'
INVOICE_NUMBER_PREFIX=UAT-INV
INVOICE_NUMBER_FORMAT='{prefix}-{fiscal_year}-{sequence}'
INVOICE_REVENUE_ACCOUNT_ID=20000000-0000-4000-8000-000000000006
INVOICE_RECEIVABLE_ACCOUNT_ID=20000000-0000-4000-8000-000000000001
BILL_NUMBER_PREFIX=UAT-BILL
BILL_NUMBER_FORMAT='{prefix}-{fiscal_year}-{sequence}'
BILL_PAYABLE_ACCOUNT_ID=20000000-0000-4000-8000-000000000004
EXPENSE_PAYABLE_ACCOUNT_ID=20000000-0000-4000-8000-000000000004
